# White-label runtime settings

# Customer-facing brand. Change these for every sold copy.
APP_BRAND_NAME=The Champ
APP_PRODUCT_NAME=The Champ BigData
APP_DEFAULT_BRAND=The Champ
APP_LOGO_URL=/assets/THE_CHAMP_logo_200x200.svg
APP_STORAGE_PREFIX=thechamp

# Local/default port.
APP_PORT=4173

# Keep production data outside the code folder.
# Windows example:
# APP_DATA_ROOT=D:\customer-data
# Linux server example:
# APP_DATA_ROOT=/var/lib/customer-panel
APP_DATA_ROOT=

# PostgreSQL target for the next migration phase.
# Example:
# DATABASE_URL=postgresql://thechamp_app:change_me@127.0.0.1:5432/thechamp_bigdata
DATABASE_URL=

# Public URL after domain/SSL is connected.
# Example:
# PUBLIC_BASE_URL=https://panel.thechamp.com
PUBLIC_BASE_URL=http://localhost:4173

# Change before production login is enabled.
APP_ADMIN_EMAIL=admin@materio.com
APP_ADMIN_PASSWORD=admin
