# The Champ runtime settings

# Local/default port.
THECHAMP_PORT=4173

# Keep production data outside the code folder.
# Windows example:
# THECHAMP_DATA_ROOT=D:\thechamp-data
# Linux server example:
# THECHAMP_DATA_ROOT=/var/lib/thechamp
THECHAMP_DATA_ROOT=

# PostgreSQL target for the next migration phase.
# Example:
# DATABASE_URL=postgresql://thechamp:change_me@127.0.0.1:5432/thechamp
DATABASE_URL=

# Public URL after domain/SSL is connected.
# Example:
# PUBLIC_BASE_URL=https://panel.thechamp.com
PUBLIC_BASE_URL=http://localhost:4173

# Change before production login is enabled.
THECHAMP_ADMIN_EMAIL=admin@materio.com
THECHAMP_ADMIN_PASSWORD=admin
